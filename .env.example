# --- Telegram ---
# Get a token from @BotFather
BOT_TOKEN=123456:ABC-your-bot-token-here

# --- Storage ---
# SQLite path, relative to the project root
DB_PATH=data/bot.db

# --- Admins ---
# Comma-separated Telegram user IDs with access to the admin panel
ADMIN_IDS=

# --- Localization ---
# Default language for new users: ru | en
DEFAULT_LANG=ru

# --- Optional paths ---
# SYSTEM_PROMPT_PATH=system_prompt/telegram_formatting.txt
# PRESETS_DIR=system_prompt/presets
